{
    "manifest_version":3,
    "name":"TextShrubs",
    "version":"1.0.0",
    "description":"Define words and change text vibes instantly.",
    "permissions":[
        "storage",
        "activeTab"
    ],
    "action":{
        "default_popup":"popup.html",
        "default_icon":"icon.png"
    },
    "host_permissions":[
        "https://api.dictionaryapi.dev/*",
        "https://api.openai.com/*"
    ],
    "content_scripts":[
        {
            "matches":[
                "<all_urls>"
            ],
            "js":[
                "content.js"
            ],
            "css":[
                "styles.css"
            ]
        }
    ]
}